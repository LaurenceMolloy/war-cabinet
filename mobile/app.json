{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "owner": "dummymolloy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "mobile",
      "war-cabinet"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsDocumentBrowser": true,
      "infoPlist": {
        "LSSupportsOpeningDocumentsInPlace": true,
        "UISupportsDocumentBrowser": true
      }
    },
    "android": {
      "package": "com.laurencemolloy.warcabinet",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      "expo-mail-composer",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you attach them to your inventory items.",
          "cameraPermission": "The app accesses your camera to let you take photos of inventory items."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow the app to use the camera to scan product expiry dates."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow the app to use the microphone for hands-free inventory audits.",
          "speechRecognitionPermission": "Allow the app to use speech recognition for hands-free inventory audits.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e55ef69-81ba-42d1-aab3-517f9da9b899"
      }
    }
  }
}
